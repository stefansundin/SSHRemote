    <string name="show_volume_slider">ஒலி அளவு ஸ்லைடரை காட்டு</string>
    <string name="control_volume_with_hardware_buttons">ஹார்ட்வேர் பொத்தான்கள் மூலம் ஒலி அளவை கட்டுப்படுத்து</string>
