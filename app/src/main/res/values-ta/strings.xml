    <!-- Share -->
    <string name="sharing">பகிர்வு</string>
    <string name="share_target_enabled">பகிர்வு இலக்கை இயக்கு</string>
    <string name="share_target_enabled_subtitle">எளிய உரை உள்ளடக்கத்திற்காக இந்த பயன்பாடு பகிர்வு மெனுவில் தோன்றும். இயல்பாக, பகிரப்பட்ட உரை இணைக்கப்பட்ட ஹோஸ்டில் keyboard type கட்டளையைப் பயன்படுத்தி தட்டச்சு செய்யப்படும்; ஆனால் இதை ஒவ்வொரு ஹோஸ்டுக்கும் தனிப்பயனாக்கலாம்.</string>
    <string name="share_target_disabled_title">பகிர்வு இலக்கு முடக்கப்பட்டுள்ளது</string>
    <string name="share_target_disabled_text">முதலில் share target அமைப்பை இயக்கு. அதை பயன்பாட்டு அமைப்புகளில் காணலாம்.</string>
    <string name="share_missing_share_command_title">பகிர்வு கட்டளை அமைக்கப்படவில்லை</string>
    <string name="share_missing_share_command_text">இந்த ஹோஸ்டில் பகிர்வு கட்டளை அமைக்கப்படவில்லை. ஹோஸ்டின் ரிமோட் கட்டுப்பாட்டைத் திருத்தி உரையைப் பகிர ஒரு கட்டளையை அமைக்கவும்.</string>
