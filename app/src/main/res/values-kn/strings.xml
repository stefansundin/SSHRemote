    <!-- Help & Volume -->
    <string name="help">ಸಹಾಯ</string>
    <string name="tap_the_help_button_for_help">ಸಹಾಯಕ್ಕಾಗಿ ? ಬಟನ್ ಒತ್ತಿರಿ.</string>
    <string name="getting_started_title">ಪ್ರಾರಂಭಿಸುವುದು</string>
    <string name="getting_started_text">ರಿಮೋಟ್ ಕಂಟ್ರೋಲ್‌ನಲ್ಲಿನ ಬಟನ್‌ಗಳು ಹೋಸ್ಟ್‌ನಲ್ಲಿ ಚಲಾಯಿಸಲ್ಪಡುವ ನಿರ್ದಿಷ್ಟ ಆಜ್ಞೆಗಳಿಗೆ ಮ್ಯಾಪ್ ಆಗಿರುತ್ತವೆ.\n\nಹೋಸ್ಟ್ ಯಾವ window manager ಅನ್ನು ಬಳಸುತ್ತದೆ ಎಂಬುದರ ಮೇಲೆ ಅವಲಂಬಿಸಿ (X11 ಅಥವಾ Wayland), ನೀವು ಸೂಕ್ತ utility ಅನ್ನು ಹೋಸ್ಟ್‌ನಲ್ಲಿ ಸ್ಥಾಪಿಸಬೇಕು.\n\nಪ್ರಾರಂಭಿಸಲು ದಯವಿಟ್ಟು ಒಂದು ಪ್ರೀಸೆಟ್ ಆಯ್ಕೆಮಾಡಿ. ನಂತರ ಯಾವಾಗ ಬೇಕಾದರೂ ರಿಮೋಟ್ ಕಂಟ್ರೋಲ್ ತಿದ್ದುದು ಮತ್ತೆ ಪ್ರೀಸೆಟ್‌ಗೆ ಮರುಹೊಂದಿಸಬಹುದು.\n\nಈ ಅಪ್ಲಿಕೇಶನ್ ಅನ್ನು ನೀವು ಮೊದಲ ಬಾರಿಗೆ ಬಳಸುತ್ತಿದ್ದರೆ ದಯವಿಟ್ಟು Help ಪುಟವನ್ನು ಓದಿ.</string>
