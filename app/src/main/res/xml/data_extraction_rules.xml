<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="."/>
        <exclude domain="database" path="encrypted_database"/>
        <exclude domain="database" path="encrypted_database-shm"/>
        <exclude domain="database" path="encrypted_database-wal"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="."/>
        <exclude domain="database" path="encrypted_database"/>
        <exclude domain="database" path="encrypted_database-shm"/>
        <exclude domain="database" path="encrypted_database-wal"/>
    </device-transfer>
</data-extraction-rules>
