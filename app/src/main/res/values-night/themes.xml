<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SSHRemote" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background_color</item>
    </style>

    <style name="Theme.SSHRemote.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SSHRemote</item>
    </style>

    <style name="Theme.SSHRemote.ShareTarget" parent="@android:style/Theme.Translucent.NoTitleBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@android:color/transparent</item>
    </style>
</resources>
